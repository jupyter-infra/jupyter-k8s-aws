# AWS cluster connection (used by all deploy targets)
# Copy this file to .env and fill in your values.
#
# All chart configuration (domain, OAuth, storage, etc.) is managed by
# jupyter-deploy terraform — deploy targets use --reuse-values to preserve
# the existing Helm release state. See CONTRIBUTING.md for the full workflow.

AWS_REGION=us-west-2
EKS_CLUSTER_NAME=jupyter-k8s-cluster

# Path to sibling jupyter-k8s checkout (for deploy-controller / deploy-controller-with-plugin)
CONTROLLER_DIR=../jupyter-k8s
